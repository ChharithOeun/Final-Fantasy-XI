# Upstream clones — refreshed via scripts/CLONE_REPOS.bat, never committed
repos/

# Large binary asset storage — never committed; published separately
assets/meshes/
assets/textures/
assets/source/

# Build / runtime artifacts
*.obj
*.fbx
*.gltf
*.glb
*.usd
*.uasset
*.umap
*.ttarchext
*.dds
*.tga
*.exr
*.bin
*.bnd
*.dat
*.png
!docs/**/*.png

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node
node_modules/
dist/
build/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*~

# Local env
.env
.env.local

# Logs
*.log
*.tmp

# UE5 editor scratch — was leaking into git status as ?? floods.
# Saved/, Intermediate/, Binaries/, DerivedDataCache/ are all
# session-local and never belong in source control.
demoncore/Saved/
demoncore/Intermediate/
demoncore/Binaries/
demoncore/DerivedDataCache/
**/Saved/
**/Intermediate/
**/Binaries/
**/DerivedDataCache/
**/webcache_*/
**/*.uproject.bak
**/*.collection
