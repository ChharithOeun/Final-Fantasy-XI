# Per-project upstream clones — refreshed via each project's scripts/CLONE_REPOS.bat
*/repos/

# Per-project heavy binary assets — never committed
*/assets/meshes/
*/assets/textures/
*/assets/source/
*/assets/audio/
*/assets/checkpoints/

# Common binary asset extensions
*.obj
*.fbx
*.gltf
*.glb
*.usd
*.uasset
*.umap
*.ttarchext
*.dds
*.tga
*.exr
*.bin
*.bnd
*.dat
*.png
!*/docs/**/*.png

# Audio (large)
*.wav
*.flac
*.ogg
*.mp3

# ML model checkpoints
*.ckpt
*.pt
*.pth
*.safetensors
*.onnx

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node
node_modules/
dist/
build/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*~

# Local env
.env
.env.local

# Logs
*.log
*.tmp
